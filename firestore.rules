rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@brolystore.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Products: allow read to everyone, write (create/update/delete) to authenticated users
    // This is secure because:
    // 1. Admin panel (where delete happens) is server-protected by session cookie
    // 2. Only admin can access /admin routes (protected by middleware/layout)
    // 3. Firestore requires any authenticated user (email doesn't matter for now)
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isSignedIn();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId',
          'items',
          'total',
          'shippingAddress',
          'paymentMethod',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.paymentMethod is string
        && request.resource.data.status == 'pending'
        && request.resource.data.shippingAddress.keys().hasOnly([
          'fullName',
          'email',
          'phone',
          'street',
          'city',
          'state',
          'zipCode',
          'country'
        ])
        && request.resource.data.shippingAddress.fullName is string
        && request.resource.data.shippingAddress.fullName.size() >= 2
        && request.resource.data.shippingAddress.email is string
        && request.resource.data.shippingAddress.phone is string
        && request.resource.data.shippingAddress.street is string
        && request.resource.data.shippingAddress.city is string
        && request.resource.data.shippingAddress.state is string
        && request.resource.data.shippingAddress.zipCode is string
        && request.resource.data.shippingAddress.country is string;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if true;
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
          'productId',
          'productName',
          'name',
          'rating',
          'text',
          'createdAt'
        ])
        && request.resource.data.productId is string
        && request.resource.data.productId.size() > 0
        && request.resource.data.productName is string
        && request.resource.data.productName.size() > 0
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 60
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 3
        && request.resource.data.text.size() <= 1200
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}


